AzureWebJobsStorage=UseDevelopmentStorage=true

AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_DEPLOYMENT=gpt-5.5

VIDEO_INDEXER_LOCATION=eastus
VIDEO_INDEXER_ACCOUNT_ID=00000000-0000-0000-0000-000000000000
VIDEO_INDEXER_ACCOUNT_NAME=your-account
VIDEO_INDEXER_RESOURCE_GROUP=your-resource-group
VIDEO_INDEXER_CALLBACK_URL=https://your-function.azurewebsites.net/api/video_indexer_callback

FRAME_INTERVAL_SECONDS=4
TRANSCRIPT_CONTEXT_SECONDS=7

SEGMENT_BATCH_SIZE_FRAMES=10
MAX_SEGMENT_WORKER_SECONDS=480
FRAME_FAILURE_MODE=continue
